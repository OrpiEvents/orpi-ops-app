# Notion — create an internal integration at notion.so/my-integrations,
# share your Sales Pipeline / Booking Tracker / Inventory databases with it,
# then paste the "Internal Integration Secret" below.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs (already in your Notion workspace)
NOTION_DB_SALES=3216ca9d054980dbb650eac5a7ec55cd
NOTION_DB_BOOKINGS=2b86ca9d0549804dbf3adf5587b8813f
NOTION_DB_INVENTORY=2e16ca9d054980cf978edf55d1d40efb
NOTION_DB_COSTING=2e36ca9d054980b2b232d8164def4997

# Supabase — create a free project at supabase.com
# Project Settings -> API -> these two values
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Project Settings -> API -> service_role key (SECRET — server only, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
